# Copy to .ozr/config.env (recommended) or export in your shell.
# Never commit real API keys or tokens.

# --- LLM ---
OZR_LLM_BACKEND=mock
OZR_LLM_API_URL=https://api.openai.com/v1/chat/completions
OZR_LLM_API_KEY=
OZR_LLM_MODEL=gpt-4o-mini

# --- MCP ---
OZR_MCP_BACKEND=mock
OZR_MCP_STDIO_COMMAND=
OZR_MCP_STDIO_ARGS=
OZR_MCP_STDIO_TIMEOUT_MS=5000
OZR_MCP_STDIO_RETRY_ATTEMPTS=2
OZR_MCP_STDIO_FRAMING=ndjson

# Real filesystem MCP (after: npm install --prefix tests/fixtures/mcp-filesystem)
# OZR_MCP_BACKEND=stdio
# OZR_MCP_STDIO_COMMAND=node
# OZR_MCP_STDIO_ARGS=tests/fixtures/mcp-filesystem/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js tests/fixtures/mcp_fs_root

# --- API server ---
OZR_API_BIND=127.0.0.1:8080

# --- Approval & policy ---
OZR_APPROVAL_MODE=prompt
OZR_POLICY_PACK=balanced
OZR_FEATURE_PONYTAIL_PROFILE=off
OZR_BUDGET_MAX_TOKENS=2000
OZR_BUDGET_MAX_ITERATIONS=5
OZR_BUDGET_MAX_RUN_SECONDS=15

# --- sandboxd (isolated execution for high-risk actions) ---
OZR_FEATURE_SANDBOXD_EXECUTOR=false
OZR_SANDBOXD_API_BASE=http://127.0.0.1:9090
OZR_SANDBOXD_API_TOKEN=
OZR_SANDBOXD_SANDBOX_ID=
OZR_SANDBOXD_AGENT=opencode
OZR_SANDBOXD_POLL_ATTEMPTS=120
OZR_SANDBOXD_POLL_INTERVAL_MS=2000
OZR_SANDBOXD_POLL_MAX_INTERVAL_MS=10000
OZR_SANDBOXD_REQUIRE_AUTH=false
OZR_SANDBOXD_HTTPS_ONLY=false

# --- Memory & vectors (optional) ---
OZR_FEATURE_MEMORY_LAYERED=false
OZR_FEATURE_VECTOR_BACKEND=none
OZR_VECTOR_EMBEDDINGS=false
OZR_MEMORY_BACKEND=sqlite
OZR_QDRANT_URL=http://127.0.0.1:6333
OZR_QDRANT_COLLECTION=ozr_memory
OZR_QDRANT_API_KEY=
OZR_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
OZR_EMBEDDING_API_KEY=
OZR_EMBEDDING_MODEL=text-embedding-3-small
OZR_EMBEDDING_DIMENSIONS=1536

# --- Feature flags ---
OZR_FEATURE_SPEC_KITTY_WORKFLOW=false
