# sandboxd settings when included from docker-compose.stack.yml
# SANDBOXD_DATA_DIR / LOG paths are injected at runtime (see docker-up-stack.sh).

PREVIEW_DOMAIN=localhost
PREVIEW_ENTRYPOINT=web
PREVIEW_TLS=false

HTTP_PORT=8081

SANDBOXD_IMAGE=sandboxd-base:1.0.0
SANDBOXD_NETWORK=ozr_stack_net

SANDBOXD_API_BIND=127.0.0.1:9090
SANDBOXD_API_AUTH_DISABLED=true
SANDBOXD_SET_MEMORY_HIGH=false
