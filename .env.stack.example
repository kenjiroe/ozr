# Copy to .env.stack (optional) for docker compose stack overrides.
# Usage: docker compose --env-file .env.stack -f docker-compose.stack.yml up -d --build

# sandboxd source (cloned by scripts/bootstrap-sandboxd-vendor.sh)
SANDBOXD_DIR=./vendor/sandboxd
# Host bind mount — required so sandboxd can docker-run workspace paths (see docs/sandboxd-local.md)
SANDBOXD_DATA_HOST_DIR=./.docker/sandboxd-data

# Standard stack ports (single source of truth)
OZR_HTTP_PORT=8080
SANDBOXD_HTTP_PORT=9090
QDRANT_HTTP_PORT=6333

OZR_LLM_BACKEND=mock
OZR_MCP_BACKEND=mock
OZR_FEATURE_SANDBOXD_EXECUTOR=true
OZR_AUTO_WIRE_SANDBOXD=true
OZR_FEATURE_VECTOR_BACKEND=qdrant
OZR_FEATURE_MEMORY_LAYERED=false
OZR_VECTOR_EMBEDDINGS=false
