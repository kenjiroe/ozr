# Copy to .ozr/config.env and adjust values for local integration runs.
# Usage: OZR_RUN_INTEGRATION=1 ./scripts/run-integration.sh

# Enable integration profile
OZR_RUN_INTEGRATION=1

# sandboxd fixture
OZR_FEATURE_SANDBOXD_EXECUTOR=true
OZR_SANDBOXD_API_BASE=http://127.0.0.1:9090
OZR_SANDBOXD_API_TOKEN=
OZR_SANDBOXD_SANDBOX_ID=
OZR_SANDBOXD_REQUIRE_AUTH=false
OZR_SANDBOXD_HTTPS_ONLY=false

# qdrant fixture
OZR_FEATURE_VECTOR_BACKEND=qdrant
OZR_QDRANT_URL=http://127.0.0.1:6333
OZR_QDRANT_COLLECTION=ozr_integration
OZR_VECTOR_EMBEDDINGS=false
